{
  "name": "GTerminalPro",
  "version": "1.0.0",
  "description": "Универсальный GUI для SQLite",
  "main": "main.js",
  "author": "Gor Tutyan",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "clean:dist": "rimraf dist && rimraf \"dist/*.7z\" 2>nul || echo cleaned",
    "build": "npm run clean:dist && electron-builder --win portable --config.win.target=portable && rimraf \"dist/win-unpacked\" \"dist/*.7z\" 2>nul || echo done",
    "build:portable": "set \"CSC_IDENTITY_AUTO_DISCOVERY=false\" && npm run clean:dist && electron-builder --win portable --config.win.target=portable && rimraf \"dist/win-unpacked\" \"dist/*.7z\" 2>nul || echo done"
  },
  "build": {
    "appId": "com.gterminalpro.app",
    "productName": "GTerminalPro",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "forceCodeSigning": false,
      "publisherName": null
    },
    "portable": {
      "artifactName": "GTerminalPro.exe",
      "useZip": false
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3"
    ],
    "npmRebuild": true,
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "login.html",
      "login.js",
      "styles.css",
      "package.json",
      "config/**/*",
      "logo.png",
      "logo.*",
      "node_modules/**/*",
      "!node_modules/**/{test,tests,examples,docs,*.md,*.markdown,CHANGELOG*,LICENSE*,*.map,*.ts,*.tsx,*.flow,*.nyc_output,.git,.github,.travis.yml,.appveyor.yml,.eslintignore,.eslintrc,.editorconfig,.nycrc,.nyc_output,.gitignore,.gitattributes,.npmignore,.jshintrc,.jshintignore,.idea,.vscode,.sublime-project,.sublime-workspace}",
      "!node_modules/better-sqlite3/{deps,src,test,tools,build/Debug,build/*.map,*.{md,ts,js.map}}",
      "!**/{.git,.github,.vscode,.idea,*.md,CHANGELOG*,LICENSE*,*.map,*.ts,*.flow,*.nyc_output}",
      "!exports/**",
      "!dist/**",
      "!data/**",
      "!*.db",
      "!*.rar",
      "!*.log",
      "!*.zip",
      "!*.7z"
    ],
    "directories": {
      "output": "dist"
    },
    "extraFiles": [],
    "extraResources": []
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "papaparse": "^5.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "rimraf": "^5.0.5"
  }
}
