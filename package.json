{
  "name": "GTerminalPro",
  "version": "1.0.0",
  "description": "Универсальный GUI для SQLite",
  "main": "main.js",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable --config.win.sign=false --config.win.forceCodeSigning=false",
    "build:portable": "set \"CSC_IDENTITY_AUTO_DISCOVERY=false\" && electron-builder --win portable --config.win.sign=false --config.win.forceCodeSigning=false"
  },
  "build": {
    "appId": "com.gterminalpro.app",
    "productName": "GTerminalPro",
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "sign": false,
      "forceCodeSigning": false,
      "publisherName": null
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "login.html",
      "login.js",
      "styles.css",
      "package.json",
      "config/**/*",
      "node_modules/**/*",
      "!node_modules/**/{test,tests,examples,docs,*.md,*.markdown,CHANGELOG*,LICENSE*,*.map,*.ts,*.tsx,*.flow,*.nyc_output,.git,.github,.travis.yml,.appveyor.yml,.eslintignore,.eslintrc,.editorconfig,.nycrc,.nyc_output,.gitignore,.gitattributes,.npmignore,.jshintrc,.jshintignore,.idea,.vscode,.sublime-project,.sublime-workspace}",
      "!**/{.git,.github,.vscode,.idea,*.md,CHANGELOG*,LICENSE*,*.map,*.ts,*.flow,*.nyc_output}",
      "!exports/**",
      "!dist/**",
      "!data/**",
      "!*.db",
      "!*.rar",
      "!*.log",
      "!*.zip",
      "!*.7z"
    ],
    "directories": {
      "output": "dist"
    },
    "afterSign": null
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "papaparse": "^5.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
